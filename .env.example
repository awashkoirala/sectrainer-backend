# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string, e.g. from Render, Railway, Supabase, or Neon
DATABASE_URL=postgres://user:password@host:5432/dbname

# Set to "false" only for local Postgres without SSL. Leave default for hosted DBs.
PGSSL=true

# A long, random, secret string used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-real-random-secret

# Your Anthropic API key, from console.anthropic.com — kept server-side only, never sent to the browser
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins, e.g. https://yoursite.netlify.app
# Use * only while testing locally.
CORS_ORIGIN=*

PORT=3000
